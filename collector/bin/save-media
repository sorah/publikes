#!/usr/bin/env ruby
# frozen_string_literal: true

$stdout.sync = true

require 'json'
require 'publikes/environment'
require 'publikes/save_media_action'
environment = Publikes::Environment.from_os

ARGV.each do |id|
  p id
  p Publikes::SaveMediaAction.new(
    environment:,
    status_id: id,
  ).perform
end
